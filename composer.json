{
  "name": "dustinscarberry/signal",
  "description": "Signal is a open source system status dashboard inspired by Cachet and others, built on Symfony and React.",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.4.0",
    "ext-ctype": "*",
    "ext-iconv": "*",
    "doctrine/common": "^3.0",
    "doctrine/dbal": "^4",
    "doctrine/doctrine-bundle": "^3",
    "doctrine/doctrine-migrations-bundle": "^4.0",
    "doctrine/orm": "^3.5",
    "hashids/hashids": "^5.0",
    "litesaml/lightsaml": "^4.1",
    "phpdocumentor/reflection-docblock": "^5.3",
    "phpstan/phpdoc-parser": "^2.3",
    "ramsey/uuid-doctrine": "^2.0",
    "symfony/asset": "8.1.*",
    "symfony/console": "8.1.*",
    "symfony/dotenv": "8.1.*",
    "symfony/event-dispatcher": "8.1.*",
    "symfony/expression-language": "8.1.*",
    "symfony/flex": "^2.3.1",
    "symfony/form": "8.1.*",
    "symfony/framework-bundle": "8.1.*",
    "symfony/intl": "8.1.*",
    "symfony/mailer": "8.1.*",
    "symfony/monolog-bundle": "^4",
    "symfony/process": "8.1.*",
    "symfony/property-access": "8.1.*",
    "symfony/property-info": "8.1.*",
    "symfony/security-bundle": "8.1.*",
    "symfony/serializer": "8.1.*",
    "symfony/templating": "6.4.*",
    "symfony/translation": "8.1.*",
    "symfony/twig-bundle": "8.1.*",
    "symfony/validator": "8.1.*",
    "symfony/web-link": "8.1.*",
    "symfony/webpack-encore-bundle": "^2.3",
    "symfony/yaml": "8.1.*"
  },
  "require-dev": {
    "dama/doctrine-test-bundle": "^8.1",
    "doctrine/doctrine-fixtures-bundle": "^4",
    "phpunit/phpunit": "^12",
    "symfony/browser-kit": "8.1.*",
    "symfony/css-selector": "8.1.*",
    "symfony/debug-bundle": "^8.1",
    "symfony/maker-bundle": "^1.11",
    "symfony/phpunit-bridge": "^8.1",
    "symfony/stopwatch": "^8.1",
    "symfony/web-profiler-bundle": "^8.1"
  },
  "config": {
    "preferred-install": {
      "*": "dist"
    },
    "sort-packages": true,
    "allow-plugins": {
      "composer/package-versions-deprecated": true,
      "symfony/flex": true
    }
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "replace": {
    "paragonie/random_compat": "2.*",
    "symfony/polyfill-ctype": "*",
    "symfony/polyfill-iconv": "*",
    "symfony/polyfill-php71": "*",
    "symfony/polyfill-php70": "*"
  },
  "scripts": {
    "update-scripts": {
      "cache:clear": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd"
    },
    "auto-scripts": {
      "assets:install %PUBLIC_DIR%": "symfony-cmd",
      "cache:clear": "symfony-cmd"
    },
    "post-install-cmd": [
      "@auto-scripts"
    ],
    "post-update-cmd": [
      "@update-scripts"
    ]
  },
  "conflict": {
    "symfony/symfony": "*"
  },
  "extra": {
    "symfony": {
      "allow-contrib": false,
      "require": "8.1.*"
    }
  }
}
